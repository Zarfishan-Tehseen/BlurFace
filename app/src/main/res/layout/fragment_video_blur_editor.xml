<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_scaffold">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_icon_circle_light"
                    android:src="@drawable/ic_back"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/cd_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvVideo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/blur_editor_title_prefix"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/blur_editor_title_suffix"
                    android:textColor="@color/purple_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvVideo"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/blur_editor_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/tvVideo"
                    app:layout_constraintStart_toStartOf="@id/tvVideo"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_white"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="5 faces selected" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSelectedFaces"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_selected_face" />

            </LinearLayout>

            <!-- Blur type -->
            <TextView
                style="@style/BlurEditor.SectionLabel"
                android:layout_marginTop="24dp"
                android:text="@string/blur_type_label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/cardGaussian"
                        style="@style/BlurEditor.OptionCard"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:tint="@color/effect_chip_text_color"
                            android:src="@drawable/ic_effect_gaussian" />

                        <TextView
                            android:id="@+id/tvGaussianTitle"
                            style="@style/BlurEditor.OptionTitle"
                            android:tint="@color/effect_chip_text_color"
                            android:text="@string/blur_type_gaussian" />

                        <TextView
                            style="@style/BlurEditor.OptionSubtitle"
                            android:text="@string/blur_type_gaussian_desc" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardMosaic"
                        style="@style/BlurEditor.OptionCard"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_effect_mosaic"
                            android:tint="@color/effect_chip_text_color"/>

                        <TextView
                            android:id="@+id/tvMosaicTitle"
                            style="@style/BlurEditor.OptionTitle"
                            android:text="@string/blur_type_mosaic" />

                        <TextView
                            style="@style/BlurEditor.OptionSubtitle"
                            android:text="@string/blur_type_mosaic_desc" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardColor"
                        style="@style/BlurEditor.OptionCard"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_effect_color"
                            android:tint="@color/effect_chip_text_color"/>

                        <TextView
                            android:id="@+id/tvColorTitle"
                            style="@style/BlurEditor.OptionTitle"
                            android:text="@string/blur_type_color" />

                        <TextView
                            style="@style/BlurEditor.OptionSubtitle"
                            android:text="@string/blur_type_color_desc"/>
                    </LinearLayout>

<!--                    <LinearLayout-->
<!--                        android:id="@+id/cardEmoji"-->
<!--                        style="@style/BlurEditor.OptionCard">-->

<!--                        <ImageView-->
<!--                            android:layout_width="24dp"-->
<!--                            android:layout_height="24dp"-->
<!--                            android:src="@drawable/ic_emoji" />-->

<!--                        <TextView-->
<!--                            android:id="@+id/tvEmojiTitle"-->
<!--                            style="@style/BlurEditor.OptionTitle"-->
<!--                            android:text="@string/blur_type_emoji" />-->

<!--                        <TextView-->
<!--                            style="@style/BlurEditor.OptionSubtitle"-->
<!--                            android:text="@string/blur_type_emoji_desc" />-->
<!--                    </LinearLayout>-->

                </LinearLayout>
            <!-- Intensity / Feather sliders -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/intensity_label"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvIntensityValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/purple_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="60%" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderIntensity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="60"
                        android:valueFrom="0"
                        android:valueTo="100"
                        app:thumbColor="@color/white"
                        app:thumbStrokeColor="@color/divider"
                        app:trackColorActive="@color/purple_primary"
                        app:trackColorInactive="@color/divider"
                        app:thumbWidth="12dp"
                        app:thumbHeight="12dp"
                        app:thumbRadius="6dp"
                        app:trackHeight="6dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/feather_label"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFeatherValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/purple_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="40%" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderFeather"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="60"
                        android:valueFrom="0"
                        android:valueTo="100"
                        app:thumbColor="@color/white"
                        app:thumbStrokeColor="@color/divider"
                        app:trackColorActive="@color/purple_primary"
                        app:trackColorInactive="@color/divider"
                        app:thumbWidth="12dp"
                        app:thumbHeight="12dp"
                        app:thumbRadius="6dp"
                        app:trackHeight="6dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Shape -->
            <TextView
                style="@style/BlurEditor.SectionLabel"
                android:layout_marginTop="16dp"
                android:text="@string/shape_label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardAutoFace"
                    style="@style/BlurEditor.OptionCard"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:tint="@color/effect_chip_text_color"
                        android:src="@drawable/ic_blur_faces" />

                    <TextView
                        android:id="@+id/tvAutoFaceTitle"
                        style="@style/BlurEditor.OptionTitle"
                        android:text="@string/shape_auto" />

                    <TextView
                        style="@style/BlurEditor.OptionSubtitle"
                        android:text="@string/shape_auto_desc" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardCircle"
                    style="@style/BlurEditor.OptionCard"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:tint="@color/effect_chip_text_color"
                        android:src="@drawable/ic_effect_gaussian" />

                    <TextView
                        android:id="@+id/tvCircleTitle"
                        style="@style/BlurEditor.OptionTitle"
                        android:text="@string/shape_circle" />

                    <TextView
                        style="@style/BlurEditor.OptionSubtitle"
                        android:text="@string/shape_circle_desc" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardRectangle"
                    style="@style/BlurEditor.OptionCard">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:tint="@color/effect_chip_text_color"
                        android:src="@drawable/ic_shape_rectangle" />

                    <TextView
                        android:id="@+id/tvRectangleTitle"
                        style="@style/BlurEditor.OptionTitle"
                        android:text="@string/shape_rectangle" />

                    <TextView
                        style="@style/BlurEditor.OptionSubtitle"
                        android:text="@string/shape_rectangle_desc" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                style="@style/BlurEditor.SectionLabel"
                android:layout_marginTop="20dp"
                android:text="@string/additional_settings_label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="33dp"
                    android:layout_height="33dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/ic_add_settings" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/blur_entire_video_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/blur_entire_video_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchBlurEntireVideo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"/>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:background="@drawable/bg_info_banner">
                <ImageView
                    android:layout_width="33dp"
                    android:layout_height="33dp"
                    android:background="@drawable/bg_circle_gradient_purple"
                    android:padding="12dp"
                    android:src="@drawable/ic_sparkle"
                    app:tint="@color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/blur_follow_info"
                    android:layout_marginStart="5dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Fixed bottom bar: CTA + privacy footer -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/bg_scaffold"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBlurFacesInVideo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_primary_gradient"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="@string/blur_faces_cta"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_lock" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/privacy_footer"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>