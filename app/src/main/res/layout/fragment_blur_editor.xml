<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_scaffold"
    android:fillViewport="true"
    android:id="@+id/scrollView"
    tools:context=".ui.blureditor.BlurEditorFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle_light"
                android:clickable="true"
                android:contentDescription="@string/cd_back"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTitleBlack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="@string/blur_editor_title_black"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:id="@+id/tvTitlePurple"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_marginStart="4dp"
                android:text="@string/blur_editor_title_purple"
                android:textColor="@color/purple_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/btnExport"
                app:layout_constraintStart_toEndOf="@id/tvTitleBlack"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blur_editor_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="@id/tvTitleBlack"
                app:layout_constraintTop_toBottomOf="@id/tvTitleBlack" />

            <ImageView
                android:id="@+id/btnExport"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle_light"
                android:clickable="true"
                android:contentDescription="@string/cd_export"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_share"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <com.example.blurface.ui.blureditor.ZoomableImageView
                android:id="@+id/zoomableImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_rounded"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/chipGaussian"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_effect_chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_effect_gaussian"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/effect_gaussian"
                        android:textColor="@color/effect_chip_text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipMosaic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_effect_chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_effect_mosaic"
                        android:tint="@color/effect_chip_text_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/effect_mosaic"
                        android:textColor="@color/effect_chip_text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipColor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_effect_chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_effect_color"
                        android:tint="@color/effect_chip_text_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/effect_color"
                        android:textColor="@color/effect_chip_text_color"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipEmoji"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/selector_effect_chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_effect_emoji"
                        android:tint="@color/effect_chip_text_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/effect_emoji"
                        android:textColor="@color/effect_chip_text_color"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="2dp"
                android:background="@color/divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/intensity_label"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvIntensityValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="60%" />

                <LinearLayout
                    android:id="@+id/btnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reset_label"
                        android:textColor="@color/purple_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_reset" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderIntensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:valueFrom="0"
                android:valueTo="100"
                app:labelBehavior="gone"

                app:thumbColor="@android:color/white"
                app:thumbElevation="4dp"
                app:thumbHeight="10dp"

                app:thumbRadius="5dp"
                app:thumbWidth="10dp"

                app:trackColorActive="@color/purple_primary"
                app:trackColorInactive="@color/accent_purple_bg"
                app:trackHeight="5dp" />

            <View
                android:id="@+id/view_colors"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="2dp"
                android:background="@color/divider"
                android:visibility="gone"
                tools:visibility="visible"/>

            <LinearLayout
                android:id="@+id/layoutColorPalette"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <View
                    android:id="@+id/colorWhite"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_white"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/colorBlack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_black"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/colorPurple"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/colorBlue"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_blue"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/colorRed"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_red"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/colorYellow"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_yellow"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/colorGreen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_color_circle_green"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <View
                android:id="@+id/view_emoji"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="2dp"
                android:background="@color/divider"
                android:visibility="gone"
                tools:visibility="visible"/>

            <LinearLayout
                android:id="@+id/layoutEmojiPalette"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/emojiSmile"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="😀"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/emojiLaugh"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="😂"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/emojiHeartEyes"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="😍"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/emojiCool"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="😎"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/emojiScared"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="😱"
                    android:textSize="24sp" />
            </LinearLayout>


        </LinearLayout>


        <!-- ── Selected faces strip ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSelectedCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Selected Faces (4)" />

            <LinearLayout
                android:id="@+id/btnClearAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear_all"
                    android:textColor="@color/purple_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_trash"
                    app:tint="@color/purple_primary"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSelectedFaces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_selected_face_chip" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_lock" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/privacy_note"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>