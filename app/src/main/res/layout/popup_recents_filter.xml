<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sort By"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/sortRecentlyUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp">

        <CheckBox
            android:id="@+id/cbSortRecentlyUpdated"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:button="@drawable/selector_radio"
            android:clickable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Recently Updated"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sortOldestFirst"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp">

        <CheckBox
            android:id="@+id/cbSortOldestFirst"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:button="@drawable/selector_radio"
            android:clickable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Oldest First"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sortName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp">

        <CheckBox
            android:id="@+id/cbSortName"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:button="@drawable/selector_radio"
            android:clickable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Name"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="12dp"
        android:background="@color/divider" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/dateToday"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp">

        <CheckBox
            android:id="@+id/cbDateToday"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:button="@drawable/selector_radio"
            android:clickable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Today"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dateThisWeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp">

        <CheckBox
            android:id="@+id/cbDateThisWeek"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:button="@drawable/selector_radio"
            android:clickable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="This Week"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dateThisMonth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp">

        <CheckBox
            android:id="@+id/cbDateThisMonth"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:button="@drawable/selector_radio"
            android:clickable="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="This Month"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>